    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Calculating weights and Generating patterns\\n\",\n",
    "    \"radius = diameter['A'] / 2  # 0.0285 m\\n\",\n",
    "    \"weights_lb = {l: math.pi * (radius**2) * length_lb[l] * density for l in long_bar_types}\\n\",\n",
    "    \"weights_rb = {r: math.pi * (radius**2) * length_rb[r] * density for r in rebar_types}\\n\",\n",
    "    \"\\n\",\n",
    "    \"customer_weight = {}\\n\",\n",
    "    \"for c in customer_areas:\\n\",\n",
    "    \"    for t in range(1, numOfPeriods + 1):\\n\",\n",
    "    \"        # Assumes demand dict is populated\\n\",\n",
    "    \"        customer_weight[c, t] = sum(demand[r, t, c] * weights_rb[r] for r in rebar_types)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def generate_patterns(long_length, rebar_lengths):\\n\",\n",
    "    \"    patterns = []\\n\",\n",
    "    \"    max_A = int(long_length // rebar_lengths['A'])\\n\",\n",
    "    \"    max_B = int(long_length // rebar_lengths['B'])\\n\",\n",
    "    \"    max_C = int(long_length // rebar_lengths['C'])\\n\",\n",
    "    \"    for a in range(max_A + 1):\\n\",\n",
    "    \"        for b in range(max_B + 1):\\n\",\n",
    "    \"            for c in range(max_C + 1):\\n\",\n",
    "    \"                total_len = a*rebar_lengths['A'] + b*rebar_lengths['B'] + c*rebar_lengths['C']\\n\",\n",
    "    \"                if 0 < total_len <= long_length:\\n\",\n",
    "    \"                    patterns.append({'A': a, 'B': b, 'C': c})\\n\",\n",
    "    \"    return patterns\\n\",\n",
    "    \"\\n\",\n",
    "    \"patterns_1 = generate_patterns(length_lb['1'], length_rb)\\n\",\n",
    "    \"patterns_2 = generate_patterns(length_lb['2'], length_rb)\"\n",
    "   ],\n",
    "   \"id\": \"d1dc6c2e9ebd03e9\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 25\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"# Build Model for each TC: Sets and Parameters, Decision Variables and Constraints\",\n",
    "   \"id\": \"d5b19f3021c4687f\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-11T16:17:17.942158Z\",\n",
    "     \"start_time\": \"2026-03-11T16:17:17.803714Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"def build_model(tc):\\n\",\n",
    "    \"    # set variable costs per km for the model\\n\",\n",
    "    \"    c_fleet = {'IJmuiden': tc, 'Segal': tc, 'South Wales': tc}\\n\",\n",
    "    \"\\n\",\n",
    "    \"    model = pe.ConcreteModel(name=\\\"Production_Delivery_Planning\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Sets\\n\",\n",
    "    \"    model.F = pe.Set(initialize=factories) # set of factories\\n\",\n",
    "    \"    model.C = pe.Set(initialize=customer_areas) # set of customers\\n\",\n",
    "    \"    model.N = pe.Set(initialize=factories + customer_areas) # set of factories + customers (all nodes in the network)\\n\",\n",
    "    \"    model.T = pe.Set(initialize=range(1, numOfPeriods + 1)) # set of periods (1, numOfperiods + 1 since it otherwise would be 0,1,2,3)\\n\",\n",
    "    \"    model.L = pe.Set(initialize=long_bar_types) # set of long bar types\\n\",\n",
    "    \"    model.R = pe.Set(initialize=rebar_types) # set of rebar types\\n\",\n",
    "    \"    model.P1 = pe.Set(initialize=range(len(patterns_1))) # set of cutting patterns for long bar type 1\\n\",\n",
    "    \"    model.P2 = pe.Set(initialize=range(len(patterns_2))) # set of cutting patterns for long bar type 2\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Parameters\\n\",\n",
    "    \"    model.dist = pe.Param(model.N, model.N, initialize=dist)\\n\",\n",
    "    \"    model.demand = pe.Param(model.R, model.T, model.C, initialize=lambda m, r, t, c: demand.get((r, t, c), 0))\\n\",\n",
    "    \"    model.steel_capacity = pe.Param(model.F, initialize=steel_capacity)\\n\",\n",
    "    \"    model.vehicle_capacity = pe.Param(initialize=vehicle_capacity)\\n\",\n",
    "    \"    model.f_fleet = pe.Param(model.F, initialize=f_fleet, within=pe.NonNegativeReals)\\n\",\n",
    "    \"    model.c_fleet = pe.Param(model.F, initialize=c_fleet, within=pe.NonNegativeReals, mutable=True)\\n\",\n",
    "    \"    model.weights_lb = pe.Param(model.L, initialize=weights_lb)\\n\",\n",
    "    \"    model.customer_weight = pe.Param(model.C, model.T, initialize=customer_weight)\\n\",\n",
    "    \"    model.inv_capacity = pe.Param(model.C, initialize = inv_capacity) # ADDED!\\n\",\n",
    "    \"    model.weights_rb = pe.Param(model.R, initialize=weights_rb) # ADDED!!\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Variables\\n\",\n",
    "    \"    model.x1 = pe.Var(model.F, model.P1, model.T, domain=pe.NonNegativeIntegers) # non-negative integer of cutting patterns from longbar type 1, produced by factory f in period t\\n\",\n",
    "    \"    model.x2 = pe.Var(model.F, model.P2, model.T, domain=pe.NonNegativeIntegers) # non-negative interger of cutting patterns from longbar type 2, produced by factory f in period t\\n\",\n",
    "    \"    model.y = pe.Var(model.F, model.C, model.T, domain=pe.Binary) # binary indicator, is customer c served by factory f in period t\\n\",\n",
    "    \"    model.z = pe.Var(model.F, model.N, model.N, model.T, domain=pe.Binary) # binary indicator, is arc N,N used during the tour from factory f in period t\\n\",\n",
    "    \"    model.w = pe.Var(model.F, model.T, domain=pe.Binary) # binary indicator, is factory f used for production and serving in period t\\n\",\n",
    "    \"    model.u = pe.Var(model.F, model.C, model.T, domain=pe.NonNegativeReals, bounds = (1, len(customer_areas))) # MTZ order variable for subtour elimination (visit position of customer c)\\n\",\n",
    "    \"    model.I = pe.Var(model.R, model.C, model.T, domain=pe.NonNegativeIntegers) # ADDED:non-negative     inventory of rebars r at customer c at the end of period t\\n\",\n",
    "    \"    model.q = pe.Var(model.F, model.R, model.C, model.T, domain=pe.NonNegativeIntegers) #ADDED: non-negative interger of rebars of type r deliverd to customer c by factory f in period t\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Objective Function\\n\",\n",
    "    \"    def obj_rule(model):\\n\",\n",
    "    \"        routing_cost = sum(model.z[f, i, j, t] * model.dist[i, j] * model.c_fleet[f]\\n\",\n",
    "    \"                       for f in model.F for i in model.N for j in model.N for t in model.T\\n\",\n",
    "    \"                       if i != j)\\n\",\n",
    "    \"        fixed_cost = sum(model.w[f, t] * model.f_fleet[f] for f in model.F for t in model.T)\\n\",\n",
    "    \"        return routing_cost + fixed_cost\\n\",\n",
    "    \"    model.Obj = pe.Objective(rule=obj_rule, sense=pe.minimize)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Constraints\\n\",\n",
    "    \"    # CHANGED: <= 1 instead of == 1, since we now do not have to assign a factory to a customer every period\\n\",\n",
    "    \"    def assign_rule(model, c, t):\\n\",\n",
    "    \"        return sum(model.y[f, c, t] for f in model.F) <= 1\\n\",\n",
    "    \"    model.AssignConstraint = pe.Constraint(model.C, model.T, rule=assign_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # CHANGED: We now produce at least what we ship instead of only the demand for this period\\n\",\n",
    "    \"    def link_prod_rule(model, f, r, t):\\n\",\n",
    "    \"        prod1 = sum(patterns_1[p][r] * model.x1[f, p, t] for p in model.P1)\\n\",\n",
    "    \"        prod2 = sum(patterns_2[p][r] * model.x2[f, p, t] for p in model.P2)\\n\",\n",
    "    \"        shipped = sum(model.q[f, r, c, t] for c in model.C)\\n\",\n",
    "    \"        return prod1 + prod2 >= shipped\\n\",\n",
    "    \"    model.LinkProdConstraint = pe.Constraint(model.F, model.R, model.T, rule=link_prod_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # NEW: Inventory rule\\n\",\n",
    "    \"    def inv_balance_rule(model, r, c, t):\\n\",\n",
    "    \"        inbound = sum(model.q[f, r, c, t] for f in model.F)\\n\",\n",
    "    \"        if t == 1:\\n\",\n",
    "    \"            return model.I[r, c, t] == inbound - model.demand[r, t, c]\\n\",\n",
    "    \"        return model.I[r, c, t] == model.I[r, c, t-1] + inbound - model.demand[r, t, c]\\n\",\n",
    "    \"    model.InvBalance = pe.Constraint(model.R, model.C, model.T, rule=inv_balance_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # NEW: Constraint that makes sure we only ship at most the total demand per customer when the factory is assigned to the customer\\n\",\n",
    "    \"    def ship_if_assigned_rule(model, f, r, c, t):\\n\",\n",
    "    \"        max_r_in_truck = math.floor(model.vehicle_capacity / model.weights_rb[r])\\n\",\n",
    "    \"        return model.q[f, r, c, t] <= max_r_in_truck * model.y[f, c, t]\\n\",\n",
    "    \"    model.ShipIfAssigned = pe.Constraint(model.F, model.R, model.C, model.T, rule=ship_if_assigned_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    #CHANGED: shipped weight is always equal to or smaller than the capacity of the vehicle (if it is used)\\n\",\n",
    "    \"    def vehicle_cap_rule(model, f, t):\\n\",\n",
    "    \"        shipped_weight = sum(model.q[f, r, c, t] * model.weights_rb[r]\\n\",\n",
    "    \"                         for r in model.R for c in model.C)\\n\",\n",
    "    \"        return shipped_weight <= model.vehicle_capacity * model.w[f, t]\\n\",\n",
    "    \"    model.VehicleCapConstraint = pe.Constraint(model.F, model.T, rule=vehicle_cap_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # NEW: Inventory capacity rule\\n\",\n",
    "    \"    def inv_cap_rule(model, c, t):\\n\",\n",
    "    \"        return sum(model.I[r, c, t] * model.weights_rb[r] for r in model.R) <= model.inv_capacity[c]\\n\",\n",
    "    \"    model.InvCap = pe.Constraint(model.C, model.T, rule=inv_cap_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def leave_factory_rule(model, f, t):\\n\",\n",
    "    \"        return sum(model.z[f, f, j, t] for j in model.C) == model.w[f, t]\\n\",\n",
    "    \"    model.LeaveFactoryConstraint = pe.Constraint(model.F, model.T, rule=leave_factory_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def return_factory_rule(model, f, t):\\n\",\n",
    "    \"        return sum(model.z[f, i, f, t] for i in model.C) == model.w[f, t]\\n\",\n",
    "    \"    model.ReturnFactoryConstraint = pe.Constraint(model.F, model.T, rule=return_factory_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def flow_in_rule(model, f, c, t):\\n\",\n",
    "    \"        return sum(model.z[f, i, c, t] for i in model.N if i != c) == model.y[f, c, t]\\n\",\n",
    "    \"    model.FlowInConstraint = pe.Constraint(model.F, model.C, model.T, rule=flow_in_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def flow_out_rule(model, f, c, t):\\n\",\n",
    "    \"        return sum(model.z[f, c, j, t] for j in model.N if j != c) == model.y[f, c, t]\\n\",\n",
    "    \"    model.FlowOutConstraint = pe.Constraint(model.F, model.C, model.T, rule=flow_out_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def no_cross_factory_rule(model, f, i, j, t):\\n\",\n",
    "    \"        if i in factories and j in factories:\\n\",\n",
    "    \"            return model.z[f, i, j, t] == 0\\n\",\n",
    "    \"        elif (i in factories and i != f) or (j in factories and j != f):\\n\",\n",
    "    \"            return model.z[f, i, j, t] == 0\\n\",\n",
    "    \"        return pe.Constraint.Skip\\n\",\n",
    "    \"    model.NoCrossFactoryConstraint = pe.Constraint(model.F, model.N, model.N, model.T, rule=no_cross_factory_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def mtz_rule(model, f, i, j, t):\\n\",\n",
    "    \"        if i != j:\\n\",\n",
    "    \"            return model.u[f, i, t] - model.u[f, j, t] + len(model.C) * model.z[f, i, j, t] <= len(model.C) - 1\\n\",\n",
    "    \"        return pe.Constraint.Skip\\n\",\n",
    "    \"    model.MTZConstraint = pe.Constraint(model.F, model.C, model.C, model.T, rule=mtz_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def factory_cap_if_active_rule(model, f, t):\\n\",\n",
    "    \"        weight_1 = sum(model.x1[f, p, t] * model.weights_lb['1'] for p in model.P1)\\n\",\n",
    "    \"        weight_2 = sum(model.x2[f, p, t] * model.weights_lb['2'] for p in model.P2)\\n\",\n",
    "    \"        return weight_1 + weight_2 <= model.steel_capacity[f] * model.w[f, t]\\n\",\n",
    "    \"    model.FactoryCapIfActive = pe.Constraint(model.F, model.T, rule=factory_cap_if_active_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Extra constraint\\n\",\n",
    "    \"    def y_implies_w_rule(m,f,c,t):\\n\",\n",
    "    \"        return m.y[f,c,t] <= m.w[f,t]\\n\",\n",
    "    \"    model.YImpliesW = pe.Constraint(model.F, model.C, model.T, rule=y_implies_w_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    #only visit when delivering\\n\",\n",
    "    \"    def deliver_if_visit_rule(m,f,c,t):\\n\",\n",
    "    \"        return sum(m.q[f,r,c,t]*m.weights_rb[r] for r in m.R) >= m.y[f,c,t]\\n\",\n",
    "    \"    model.DeliverIfVisit = pe.Constraint(model.F, model.C, model.T, rule=deliver_if_visit_rule)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return model\\n\",\n",
    "    \"\\n\"\n",
    "   ],\n",
    "   \"id\": \"d8cfaa94f1e73ffc\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 26\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"# Sensitivity Analysis for TC\",\n",
    "   \"id\": \"c4e73f285e45e158\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-11T17:03:56.656165Z\",\n",
    "     \"start_time\": \"2026-03-11T16:17:17.953040Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Print optimal plans for TC in [1,5]\\n\",\n",
    "    \"def print_optimal_plan_for_current_solution(model, patterns_1, patterns_2, weights_lb, weights_rb, steel_capacity, vehicle_capacity, tc_value):\\n\",\n",
    "    \"    print(f\\\"\\\\n===================== OPTIMAL PLAN FOR TC = €{tc_value}/km =====================\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for t in model.T:\\n\",\n",
    "    \"        print(f\\\"\\\\n================ PERIOD {t} ================\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for f in model.F:\\n\",\n",
    "    \"            if value(model.w[f, t]) > 0.5:\\n\",\n",
    "    \"                print(f\\\"\\\\nFactory: {f}\\\")\\n\",\n",
    "    \"                total_steel_used = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"                # ---------------------------\\n\",\n",
    "    \"                # Production\\n\",\n",
    "    \"                # ---------------------------\\n\",\n",
    "    \"                print(\\\"\\\\n Production:\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for p in model.P1:\\n\",\n",
    "    \"                    val = value(model.x1[f, p, t])\\n\",\n",
    "    \"                    if val and val > 1e-6:\\n\",\n",
    "    \"                        bars = int(round(val))\\n\",\n",
    "    \"                        total_steel_used += bars * weights_lb['1']\\n\",\n",
    "    \"                        print(f\\\"  • {bars}x 9m bars met patroon {patterns_1[p]}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for p in model.P2:\\n\",\n",
    "    \"                    val = value(model.x2[f, p, t])\\n\",\n",
    "    \"                    if val and val > 1e-6:\\n\",\n",
    "    \"                        bars = int(round(val))\\n\",\n",
    "    \"                        total_steel_used += bars * weights_lb['2']\\n\",\n",
    "    \"                        print(f\\\"  • {bars}x 12m bars met patroon {patterns_2[p]}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"                print(f\\\"  Steel used: {total_steel_used:.2f} / {steel_capacity[f]} tonnes\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"                # ---------------------------\\n\",\n",
    "    \"                # Route\\n\",\n",
    "    \"                # ---------------------------\\n\",\n",
    "    \"                print(\\\"\\\\n Delivery Route:\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"                curr_node = f\\n\",\n",
    "    \"                route = [curr_node]\\n\",\n",
    "    \"                visited_guard = set([curr_node])\\n\",\n",
    "    \"                while True:\\n\",\n",
    "    \"                    next_node = None\\n\",\n",
    "    \"                    for j in model.N:\\n\",\n",
    "    \"                        if curr_node != j and value(model.z[f, curr_node, j, t]) > 0.5:\\n\",\n",
    "    \"                            next_node = j\\n\",\n",
    "    \"                            break\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    if next_node is None or next_node == f or next_node in visited_guard:\\n\",\n",
    "    \"                        route.append(f)\\n\",\n",
    "    \"                        break\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    route.append(next_node)\\n\",\n",
    "    \"                    visited_guard.add(next_node)\\n\",\n",
    "    \"                    curr_node = next_node\\n\",\n",
    "    \"\\n\",\n",
    "    \"                print(\\\"  Route:\\\", \\\" ➔ \\\".join(route))\\n\",\n",
    "    \"\\n\",\n",
    "    \"                # ---------------------------\\n\",\n",
    "    \"                # Shipments\\n\",\n",
    "    \"                # ---------------------------\\n\",\n",
    "    \"                print(\\\"\\\\n Shipments (rebars):\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"                total_vehicle_load = 0.0\\n\",\n",
    "    \"                for c in model.C:\\n\",\n",
    "    \"                    qtyA = int(round(value(model.q[f, 'A', c, t])))\\n\",\n",
    "    \"                    qtyB = int(round(value(model.q[f, 'B', c, t])))\\n\",\n",
    "    \"                    qtyC = int(round(value(model.q[f, 'C', c, t])))\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    if qtyA + qtyB + qtyC > 0:\\n\",\n",
    "    \"                        print(f\\\"  {c}: A={qtyA}, B={qtyB}, C={qtyC}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    total_vehicle_load += (\\n\",\n",
    "    \"                        value(model.q[f, 'A', c, t]) * weights_rb['A'] +\\n\",\n",
    "    \"                        value(model.q[f, 'B', c, t]) * weights_rb['B'] +\\n\",\n",
    "    \"                        value(model.q[f, 'C', c, t]) * weights_rb['C']\\n\",\n",
    "    \"                    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"                print(f\\\"\\\\n  Vehicle load: {total_vehicle_load:.2f} / {vehicle_capacity} tonnes\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # ---------------------------\\n\",\n",
    "    \"        # Inventory per customer\\n\",\n",
    "    \"        # ---------------------------\\n\",\n",
    "    \"        print(\\\"\\\\n End Inventory (rebars):\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for c in model.C:\\n\",\n",
    "    \"            invA = int(round(value(model.I['A', c, t])))\\n\",\n",
    "    \"            invB = int(round(value(model.I['B', c, t])))\\n\",\n",
    "    \"            invC = int(round(value(model.I['C', c, t])))\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if invA + invB + invC > 0:\\n\",\n",
    "    \"                total_inv_weight = (\\n\",\n",
    "    \"                    invA * weights_rb['A'] +\\n\",\n",
    "    \"                    invB * weights_rb['B'] +\\n\",\n",
    "    \"                    invC * weights_rb['C']\\n\",\n",
    "    \"                )\\n\",\n",
    "    \"                print(f\\\"  {c}: A={invA}, B={invB}, C={invC} \\\"\\n\",\n",
    "    \"                      f\\\"({total_inv_weight:.2f} / {float(model.inv_capacity[c])} tonnes)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Sensitivity run: solve for TC in [1,5.5], prints optimal plan and collect strings with important values for the sensitivity analysis\\n\",\n",
    "    \"def run_sensitivity_TC_and_collect_strings(\\n\",\n",
    "    \"    patterns_1, patterns_2, weights_lb, weights_rb, steel_capacity, vehicle_capacity,\\n\",\n",
    "    \"    TC_values, time_limit=1800, tee=False\\n\",\n",
    "    \"):\\n\",\n",
    "    \"\\n\",\n",
    "    \"    TC_list = []\\n\",\n",
    "    \"    OBJ_values = []\\n\",\n",
    "    \"    INV_units_sum = []\\n\",\n",
    "    \"    INV_tons_sum = []\\n\",\n",
    "    \"    COMP_time_sec = []\\n\",\n",
    "    \"    MIP_gap_pct = []\\n\",\n",
    "    \"    NODES_explored = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    TOURS_p1 = []\\n\",\n",
    "    \"    TOURS_p2 = []\\n\",\n",
    "    \"    TOURS_p3 = []\\n\",\n",
    "    \"    TOURS_p4 = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    PROD_pct_IJ = []\\n\",\n",
    "    \"    PROD_pct_SE = []\\n\",\n",
    "    \"    PROD_pct_SW = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for tc in TC_values:\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"\\\\n========== Solving TC = {tc} ==========\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        model = build_model(tc)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        solver = po.SolverFactory('gurobi')\\n\",\n",
    "    \"\\n\",\n",
    "    \"        start = time.time()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        results = solver.solve(\\n\",\n",
    "    \"            model,\\n\",\n",
    "    \"            tee=tee,\\n\",\n",
    "    \"            options={\\n\",\n",
    "    \"                'TimeLimit': time_limit,\\n\",\n",
    "    \"                'MIPGap': 0.05\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        runtime = time.time() - start\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # -----------------------------\\n\",\n",
    "    \"        # Solver status\\n\",\n",
    "    \"        # -----------------------------\\n\",\n",
    "    \"        status = results.solver.status\\n\",\n",
    "    \"        termination = results.solver.termination_condition\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # objective value\\n\",\n",
    "    \"        gap_pct = None\\n\",\n",
    "    \"        nodes = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        #  objective value\\n\",\n",
    "    \"        objective = float(value(model.Obj))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Try Pyomo mip_gap first\\n\",\n",
    "    \"        if hasattr(results.solver, \\\"mip_gap\\\") and results.solver.mip_gap is not None:\\n\",\n",
    "    \"            gap_pct = results.solver.mip_gap * 100\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Otherwise compute manually\\n\",\n",
    "    \"        elif hasattr(results.problem, \\\"lower_bound\\\") and results.problem.lower_bound is not None:\\n\",\n",
    "    \"            bound = results.problem.lower_bound\\n\",\n",
    "    \"            if abs(objective) > 1e-9:\\n\",\n",
    "    \"                gap_pct = abs(objective - bound) / abs(objective) * 100\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Nodes\\n\",\n",
    "    \"        if hasattr(results.solver, \\\"branch_and_bound_nodes\\\") and results.solver.branch_and_bound_nodes is not None:\\n\",\n",
    "    \"            nodes = results.solver.branch_and_bound_nodes\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"Status: {status}\\\")\\n\",\n",
